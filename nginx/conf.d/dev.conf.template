server {
    listen 443 ssl;
    server_name weakkey.${BASE_DOMAIN};
    ssl_certificate /certs/server/weakkey.crt;
    ssl_certificate_key /certs/server/weakkey.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers DEFAULT:@SECLEVEL=0;
    ssl_conf_command CipherString DEFAULT:@SECLEVEL=0;
    default_type application/json;
    return 200 '{"case":"weakkey","status":"ok","message":"Weak RSA-1024 certificate for fixed dev test case."}';
}

