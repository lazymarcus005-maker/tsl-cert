map $host $case_name {
    default "unknown";
    valid.${BASE_DOMAIN} "valid";
    expired.${BASE_DOMAIN} "expired";
    notyet.${BASE_DOMAIN} "notyet";
    wronghost.${BASE_DOMAIN} "wronghost";
    selfsigned.${BASE_DOMAIN} "selfsigned";
    untrustedca.${BASE_DOMAIN} "untrustedca";
    weakkey.${BASE_DOMAIN} "weakkey";
    wrongusage.${BASE_DOMAIN} "wrongusage";
    wildcard.${BASE_DOMAIN} "wildcard";
    revoked.${BASE_DOMAIN} "revoked";
}

server {
    listen 443 ssl;
    server_name valid.${BASE_DOMAIN};
    ssl_certificate /certs/server/valid.crt;
    ssl_certificate_key /certs/server/valid.key;
    ssl_protocols TLSv1.2 TLSv1.3;

    location / {
        proxy_pass ${BACKEND_URL};
        proxy_ssl_server_name on;
        proxy_set_header Host $proxy_host;
        proxy_set_header X-Forwarded-By mxlabs.cloud;
        proxy_set_header X-Test-Lab ssl-testlab.mxlabs.cloud;
        proxy_set_header X-Test-Case valid;
        add_header X-Forwarded-By mxlabs.cloud always;
        add_header X-Test-Lab ssl-testlab.mxlabs.cloud always;
        add_header X-Test-Case valid always;
    }
}

server {
    listen 443 ssl;
    server_name expired.${BASE_DOMAIN};
    ssl_certificate /certs/server/expired.crt;
    ssl_certificate_key /certs/server/expired.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    default_type application/json;
    return 200 '{"case":"expired","status":"ok","message":"Expired certificate for fixed dev test case."}';
}

server {
    listen 443 ssl;
    server_name notyet.${BASE_DOMAIN};
    ssl_certificate /certs/server/notyet.crt;
    ssl_certificate_key /certs/server/notyet.key;
    ssl_protocols TLSv1.2 TLSv1.3;
